{
  "$ref": "#/definitions/VerifiableCredentialSubject",
  "definitions": {
    "VerifiableCredentialSubject": {
      "type": "object",
      "properties": {
        "projectTitle": {
          "type": "string"
        },
        "conceptsDemonstrated": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "masteryScore": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            },
            "required": [
              "id",
              "name",
              "masteryScore"
            ],
            "additionalProperties": false
          }
        },
        "competencyRadar": {
          "type": "object",
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "proofOfStruggle": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "errorSignature": {
                "type": "string"
              },
              "fixDiff": {
                "type": "string"
              },
              "defenseAnswerId": {
                "type": "string"
              }
            },
            "required": [
              "errorSignature",
              "fixDiff",
              "defenseAnswerId"
            ],
            "additionalProperties": false
          }
        },
        "interviewSummary": {
          "type": "object",
          "properties": {
            "phases": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "phase": {
                    "type": "string"
                  },
                  "questions": {
                    "type": "integer"
                  }
                },
                "required": [
                  "phase",
                  "questions"
                ],
                "additionalProperties": false
              }
            },
            "overallRubric": {
              "type": "object",
              "properties": {
                "correctness": {
                  "type": "number"
                },
                "reasoningDepth": {
                  "type": "number"
                },
                "tradeoffAwareness": {
                  "type": "number"
                }
              },
              "required": [
                "correctness",
                "reasoningDepth",
                "tradeoffAwareness"
              ],
              "additionalProperties": false
            }
          },
          "required": [
            "phases",
            "overallRubric"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "projectTitle",
        "conceptsDemonstrated",
        "competencyRadar",
        "proofOfStruggle",
        "interviewSummary"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
