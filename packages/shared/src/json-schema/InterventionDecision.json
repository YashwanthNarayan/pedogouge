{
  "$ref": "#/definitions/InterventionDecision",
  "definitions": {
    "InterventionDecision": {
      "type": "object",
      "properties": {
        "tier": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "conceptId": {
          "type": "string"
        },
        "rationale": {
          "type": "string",
          "maxLength": 200
        },
        "expectedDurationSeconds": {
          "type": "integer"
        },
        "fallbackTierIfStillStuck": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "deliveryChannel": {
          "type": "string",
          "enum": [
            "chat",
            "inline",
            "codelens",
            "notebook",
            "debug",
            "terminal"
          ]
        }
      },
      "required": [
        "tier",
        "conceptId",
        "rationale",
        "expectedDurationSeconds",
        "fallbackTierIfStillStuck",
        "deliveryChannel"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
