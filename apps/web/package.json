{
  "name": "@pedagogue/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "credential:keygen": "node -e \"const{generateKeyPair,exportJWK}=require('jose');(async()=>{const{privateKey,publicKey}=await generateKeyPair('EdDSA',{crv:'Ed25519',extractable:true});console.log('CREDENTIAL_PRIVATE_KEY_JWK='+JSON.stringify(await exportJWK(privateKey)));console.log('CREDENTIAL_PUBLIC_KEY_JWK='+JSON.stringify(await exportJWK(publicKey)))})();\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "@deepgram/sdk": "latest",
    "@pedagogue/shared": "workspace:*",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.46.0",
    "@upstash/ratelimit": "latest",
    "@upstash/redis": "latest",
    "canonicalize": "^2.0.0",
    "d3": "^7.9.0",
    "diff-match-patch": "^1.0.5",
    "elevenlabs": "latest",
    "framer-motion": "^11.11.0",
    "isomorphic-git": "^1.27.0",
    "jose": "^5.9.0",
    "jszip": "^3.10.1",
    "lucide-react": "latest",
    "monaco-editor": "^0.52.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-qr-code": "^2.0.15",
    "recharts": "^2.13.0",
    "voyageai": "latest",
    "y-monaco": "^0.1.5",
    "y-websocket": "^2.0.4",
    "yjs": "^13.6.20",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/diff-match-patch": "^1.0.36",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.0",
    "ws": "^8.18.0"
  }
