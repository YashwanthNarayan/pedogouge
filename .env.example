# ============================================================
# Pedagogue — Environment Variables
# Copy to .env.local for local development.
# NEVER commit .env.local or any file with real secrets.
# ============================================================

# ── Anthropic ──────────────────────────────────────────────
# API key from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Model IDs (defaults; override to test different models)
ANTHROPIC_DEFAULT_MODEL=claude-opus-4-7
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_INTERACTIVE_MODEL=claude-sonnet-4-6

# Required for 300K output tokens beta
ANTHROPIC_BETA_HEADERS=output-300k-2026-03-24

# ── Voyage AI (embeddings) ─────────────────────────────────
# API key from dash.voyageai.com
VOYAGE_API_KEY=pa-...

# ── Deepgram (ASR) ─────────────────────────────────────────
# API key from console.deepgram.com
# IMPORTANT: Enable "no retention" in Deepgram console and set retain=false per-request
DEEPGRAM_API_KEY=...

# ── ElevenLabs (TTS) ───────────────────────────────────────
# API key from elevenlabs.io
ELEVENLABS_API_KEY=...

# Pre-chosen interviewer voice ID (configure in ElevenLabs dashboard)
ELEVENLABS_VOICE_ID=...

# ── Supabase ───────────────────────────────────────────────
# Project URL from supabase.com/dashboard/project/{ref}/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Anon (public) key — safe to expose to browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — NEVER expose to browser; backend only
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Judge0 (code execution) ────────────────────────────────
# Self-hosted Judge0 base URL (see infra/judge0/ for setup)
JUDGE0_BASE_URL=https://judge0.pedagogue-demo.com

# Auth token from judge0.conf AUTHN_TOKEN
JUDGE0_AUTH_TOKEN=...

# HMAC secret for webhook signature verification
JUDGE0_CALLBACK_SECRET=...

# Fallback: RapidAPI Judge0 CE (feature-flagged; used if self-host is unreachable)
JUDGE0_FALLBACK_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_FALLBACK_RAPIDAPI_KEY=...

# ── Yjs relay (teacher collab) ─────────────────────────────
# y-websocket server URL on Fly.io (see infra/y-websocket/)
NEXT_PUBLIC_YWS_URL=wss://pedagogue-yws.fly.dev

# ── Credential signing ─────────────────────────────────────
# Ed25519 keypair in JWK format — generate with: pnpm --filter @pedagogue/web credential:keygen
# Both vars are required; private key never leaves the server
CREDENTIAL_PRIVATE_KEY_JWK={"kty":"OKP","crv":"Ed25519","x":"...","d":"..."}
CREDENTIAL_PUBLIC_KEY_JWK={"kty":"OKP","crv":"Ed25519","x":"..."}

# HMAC fallback secret (kept for backward-compat; Ed25519 is primary)
CREDENTIAL_HMAC_SECRET=...

# ── GitHub OAuth ───────────────────────────────────────────
# OAuth app from github.com/settings/developers
# Callback URL to register: {APP_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=...
GITHUB_CLIENT_SECRET=...
# Exposed to browser for the /auth/extension sign-in button
NEXT_PUBLIC_GITHUB_CLIENT_ID=...

# JWT secret for signing extension session tokens (generate: openssl rand -hex 32)
JWT_SECRET=...

# GitHub App credentials (for Classroom integration — stretch goal)
GITHUB_APP_ID=...
GITHUB_APP_PRIVATE_KEY=...

# ── Upstash Redis (rate limiting) ──────────────────────────
# From console.upstash.com → Create Database → REST API
# Tiers: api=100/min, ai=20/min, auth=10/10min — omit in local dev to skip limiting
UPSTASH_REDIS_REST_URL=https://<db>.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# ── Expo (mobile push notifications) ──────────────────────
# From expo.dev — used by Supabase Edge Function for SM-2 notifications
EXPO_ACCESS_TOKEN=...

# ── App config ─────────────────────────────────────────────
# Public URL (used for callback URLs, credential links, etc.)
NEXT_PUBLIC_APP_URL=https://pedagogue.app

NODE_ENV=development

# ── Development overrides ──────────────────────────────────
# Set to "true" to skip real external services during local dev
PEDAGOGUE_MOCK_AUTH=false
PEDAGOGUE_MOCK_CHAT=false
PEDAGOGUE_MOCK_EXECUTE=false
NEXT_PUBLIC_DEFENSE_MOCK=false
